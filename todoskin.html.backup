        <!-- Template Stylesheet -->
        <link href="css/style.css" rel="stylesheet">
    <style>
        .section-tabs {
            text-align: center;
            margin-bottom: 30px;
        }
        .section-filter {
            list-style: none;
            display: inline-flex;
            gap: 10px;
            padding: 0;
            margin: 0;
        }
        .section-filter li {
            padding: 10px 24px;
            font-size: 14px;
            font-weight: 600;
            color: var(--color-text);
            background: var(--color-white);
            border: 1px solid rgba(0,0,0,0.08);
            border-radius: 24px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .section-filter li:hover,
        .section-filter li.filter-active {
            background: var(--color-primary);
            color: var(--color-white);
            border-color: var(--color-primary);
        }
        .catalog-section-content {
            display: none;
        }
        .catalog-section-content.active {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            padding: 8px 60px 24px;
        }
        @media (max-width: 1200px) {
            .catalog-section-content.active {
                grid-template-columns: repeat(2, 1fr);
                padding: 8px 28px;
            }
        }
        @media (max-width: 575px) {
            .catalog-section-content.active {
                grid-template-columns: 1fr;
                padding: 8px 16px;
            }
        }
    </style>
</head>

