                <!-- JavaScript for section switching -->
                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        const filterItems = document.querySelectorAll('.section-filter li');
                        const sections = document.querySelectorAll('.catalog-section-content');

                        filterItems.forEach(item => {
                            item.addEventListener('click', function() {
                                // Remove active class from all items
                                filterItems.forEach(i => i.classList.remove('filter-active'));
                                // Add active class to clicked item
                                this.classList.add('filter-active');

                                // Hide all sections
                                sections.forEach(section => section.classList.remove('active'));
                                // Show target section
                                const target = this.getAttribute('data-target');
                                document.getElementById(target).classList.add('active');
                            });
                        });
                    });
                </script>
